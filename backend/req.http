@baseUrl = http://localhost:5000/api
@email = tester@example.com
@password = Password123
@token = paste-jwt-token-here
@resumeId = paste-resume-id-here

### Health
GET {{baseUrl}}/health

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Resume history
GET {{baseUrl}}/resume/history
Authorization: Bearer {{token}}

### Resume by id
GET {{baseUrl}}/resume/{{resumeId}}
Authorization: Bearer {{token}}

### Upload resume
# Replace ./sample-resume.pdf with a real PDF or DOCX file path before sending this request.
POST {{baseUrl}}/resume/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=ResumeBoundary

--ResumeBoundary
Content-Disposition: form-data; name="resume"; filename="sample-resume.pdf"
Content-Type: application/pdf

< ./sample-resume.pdf
--ResumeBoundary--
